generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email             String        @unique
  passwordHash      String        @map("password_hash")
  displayName       String?       @map("display_name")
  role              UserRole      @default(VIEWER)
  status            UserStatus    @default(INVITED)
  telegramId        String?       @unique @map("telegram_id")
  telegramUsername  String?       @map("telegram_username")
  telegramFirstName String?       @map("telegram_first_name")
  telegramLastName  String?       @map("telegram_last_name")
  telegramPhotoUrl  String?       @map("telegram_photo_url")
  supervisorId      String?       @db.Uuid @map("supervisor_id")
  lastSeenAt        DateTime?     @map("last_seen_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  sessions          AuthSession[]
  assignedClients   ClientPoint[] @relation("AssignedRepClients")
  visits            Visit[]       @relation("SalesRepVisits")
  orders            Order[]       @relation("SalesRepOrders")
  supervisor        User?         @relation("SupervisorManagers", fields: [supervisorId], references: [id], map: "users_supervisor_id_fkey")
  assignedManagers  User[]        @relation("SupervisorManagers")
  managerProfile    ManagerProfile?
  assignedDeals     Deal[]        @relation("AssignedManagerDeals")
  createdDeals      Deal[]        @relation("CreatedDeals")
  functionUpdates   FunctionSetting[] @relation("FunctionSettingUpdater")
  scriptUpdates     SalesScript[] @relation("SalesScriptUpdater")
  activityActors    ActivityLog[] @relation("ActivityActor")
  activityTargets   ActivityLog[] @relation("ActivityTarget")
  dailyMetrics      ManagerDailyMetric[]

  @@index([role], map: "users_role_idx")
  @@index([status], map: "users_status_idx")
  @@index([supervisorId], map: "users_supervisor_id_idx")
  @@map("users")
}

model AuthSession {
  id               String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId           String    @db.Uuid @map("user_id")
  refreshTokenHash String    @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "auth_sessions_user_id_fkey")

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

enum UserRole {
  OWNER
  ADMIN
  SUPERVISOR
  MANAGER
  VIEWER
  SALES_REP
}

enum UserStatus {
  ACTIVE
  BLOCKED
  INVITED
  DISABLED
}

model ManagerProfile {
  userId        String   @id @db.Uuid @map("user_id")
  displayName   String?  @map("display_name")
  phone         String?
  timezone      String   @default("Asia/Dubai")
  workingStatus String   @default("available") @map("working_status")
  notes         String?
  dailyLimit    Int?     @map("daily_limit")
  monthlyLimit  Int?     @map("monthly_limit")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "manager_profiles_user_id_fkey")

  @@map("manager_profiles")
}

model Deal {
  id                String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  title             String
  clientName        String     @map("client_name")
  source            String?
  status            DealStatus @default(NEW)
  amount            Decimal    @default(0) @db.Decimal(12, 2)
  assignedManagerId String?    @db.Uuid @map("assigned_manager_id")
  createdBy         String?    @db.Uuid @map("created_by")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  closedAt          DateTime?  @map("closed_at")
  assignedManager   User?      @relation("AssignedManagerDeals", fields: [assignedManagerId], references: [id], map: "deals_assigned_manager_id_fkey")
  creator           User?      @relation("CreatedDeals", fields: [createdBy], references: [id], map: "deals_created_by_fkey")

  @@index([assignedManagerId], map: "deals_assigned_manager_id_idx")
  @@index([status], map: "deals_status_idx")
  @@index([createdAt], map: "deals_created_at_idx")
  @@map("deals")
}

enum DealStatus {
  NEW
  TAKEN
  IN_PROGRESS
  SUCCESS
  CANCELLED
}

model FunctionSetting {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  key         String   @unique
  title       String
  description String?
  valueJson   Json     @default("{}") @map("value_json")
  enabled     Boolean  @default(true)
  updatedBy   String?  @db.Uuid @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updater     User?    @relation("FunctionSettingUpdater", fields: [updatedBy], references: [id], map: "function_settings_updated_by_fkey")

  @@map("function_settings")
}

model SalesScript {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  title     String
  body      String
  category  String?
  enabled   Boolean  @default(true)
  updatedBy String?  @db.Uuid @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updater   User?    @relation("SalesScriptUpdater", fields: [updatedBy], references: [id], map: "sales_scripts_updated_by_fkey")

  @@index([enabled], map: "sales_scripts_enabled_idx")
  @@map("sales_scripts")
}

model ActivityLog {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  actorUserId  String   @db.Uuid @map("actor_user_id")
  targetUserId String?  @db.Uuid @map("target_user_id")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  action       String
  payloadJson  Json     @default("{}") @map("payload_json")
  createdAt    DateTime @default(now()) @map("created_at")
  actor        User     @relation("ActivityActor", fields: [actorUserId], references: [id], map: "activity_logs_actor_user_id_fkey")
  target       User?    @relation("ActivityTarget", fields: [targetUserId], references: [id], map: "activity_logs_target_user_id_fkey")

  @@index([actorUserId], map: "activity_logs_actor_user_id_idx")
  @@index([targetUserId], map: "activity_logs_target_user_id_idx")
  @@index([entityType, entityId], map: "activity_logs_entity_idx")
  @@index([createdAt], map: "activity_logs_created_at_idx")
  @@map("activity_logs")
}

model ManagerDailyMetric {
  id                 String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  managerId          String   @db.Uuid @map("manager_id")
  date               DateTime @db.Date
  leadsNew           Int      @default(0) @map("leads_new")
  leadsTaken         Int      @default(0) @map("leads_taken")
  dealsSuccess       Int      @default(0) @map("deals_success")
  dealsCancelled     Int      @default(0) @map("deals_cancelled")
  totalAmount        Decimal  @default(0) @db.Decimal(12, 2) @map("total_amount")
  avgResponseSeconds Int      @default(0) @map("avg_response_seconds")
  messagesCount      Int      @default(0) @map("messages_count")
  conversionRate     Decimal  @default(0) @db.Decimal(5, 2) @map("conversion_rate")
  manager            User     @relation(fields: [managerId], references: [id], onDelete: Cascade, map: "manager_daily_metrics_manager_id_fkey")

  @@unique([managerId, date], map: "manager_daily_metrics_manager_id_date_key")
  @@index([date], map: "manager_daily_metrics_date_idx")
  @@map("manager_daily_metrics")
}

model ClientPoint {
  id              String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name            String
  type            ClientPointType
  contactPerson   String?           @map("contact_person")
  phone           String?
  city            String
  address         String
  latitude        Decimal?          @db.Decimal(9, 6)
  longitude       Decimal?          @db.Decimal(9, 6)
  assignedRepId   String            @db.Uuid @map("assigned_rep_id")
  status          ClientPointStatus @default(ACTIVE)
  comment         String?
  lastVisitAt     DateTime?         @map("last_visit_at")
  nextVisitAt     DateTime?         @map("next_visit_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  assignedRep     User              @relation("AssignedRepClients", fields: [assignedRepId], references: [id], map: "client_points_assigned_rep_id_fkey")
  visits          Visit[]
  orders          Order[]

  @@index([assignedRepId], map: "client_points_assigned_rep_id_idx")
  @@index([status], map: "client_points_status_idx")
  @@map("client_points")
}

model ProductCategory {
  id          String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("product_categories")
}

model Product {
  id          String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name        String
  categoryId  String          @db.Uuid @map("category_id")
  viscosity   String?
  volume      String
  sku         String          @unique
  basePrice   Decimal         @map("base_price") @db.Decimal(12, 2)
  currency    String          @default("AED")
  description String?
  isActive    Boolean         @default(true) @map("is_active")
  stock       Int?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  category    ProductCategory @relation(fields: [categoryId], references: [id], map: "products_category_id_fkey")
  orderItems  OrderItem[]

  @@index([categoryId], map: "products_category_id_idx")
  @@index([isActive], map: "products_is_active_idx")
  @@map("products")
}

model Visit {
  id            String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  clientPointId String       @db.Uuid @map("client_point_id")
  salesRepId    String       @db.Uuid @map("sales_rep_id")
  plannedAt     DateTime     @map("planned_at")
  startedAt     DateTime?    @map("started_at")
  completedAt   DateTime?    @map("completed_at")
  status        VisitStatus  @default(PLANNED)
  result        VisitResult?
  comment       String?
  latitude      Decimal?     @db.Decimal(9, 6)
  longitude     Decimal?     @db.Decimal(9, 6)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  clientPoint   ClientPoint  @relation(fields: [clientPointId], references: [id], map: "visits_client_point_id_fkey")
  salesRep      User         @relation("SalesRepVisits", fields: [salesRepId], references: [id], map: "visits_sales_rep_id_fkey")
  orders        Order[]

  @@index([salesRepId], map: "visits_sales_rep_id_idx")
  @@index([clientPointId], map: "visits_client_point_id_idx")
  @@index([plannedAt], map: "visits_planned_at_idx")
  @@map("visits")
}

model Order {
  id            String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orderNumber   String      @unique @map("order_number")
  clientPointId String      @db.Uuid @map("client_point_id")
  salesRepId    String      @db.Uuid @map("sales_rep_id")
  visitId       String?     @db.Uuid @map("visit_id")
  status        OrderStatus @default(DRAFT)
  subtotal      Decimal     @default(0) @db.Decimal(12, 2)
  discount      Decimal     @default(0) @db.Decimal(12, 2)
  total         Decimal     @default(0) @db.Decimal(12, 2)
  comment       String?
  managerComment String?    @map("manager_comment")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  clientPoint   ClientPoint @relation(fields: [clientPointId], references: [id], map: "orders_client_point_id_fkey")
  salesRep      User        @relation("SalesRepOrders", fields: [salesRepId], references: [id], map: "orders_sales_rep_id_fkey")
  visit         Visit?      @relation(fields: [visitId], references: [id], map: "orders_visit_id_fkey")
  items         OrderItem[]

  @@index([salesRepId], map: "orders_sales_rep_id_idx")
  @@index([clientPointId], map: "orders_client_point_id_idx")
  @@index([status], map: "orders_status_idx")
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orderId   String   @db.Uuid @map("order_id")
  productId String   @db.Uuid @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "order_items_order_id_fkey")
  product   Product  @relation(fields: [productId], references: [id], map: "order_items_product_id_fkey")

  @@index([orderId], map: "order_items_order_id_idx")
  @@index([productId], map: "order_items_product_id_idx")
  @@map("order_items")
}

enum ClientPointType {
  AUTO_SHOP
  SERVICE_STATION
  WHOLESALE
  RETAIL
  OTHER
}

enum ClientPointStatus {
  ACTIVE
  PAUSED
  LEAD
  ARCHIVED
}

enum VisitStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum VisitResult {
  ORDER_CREATED
  NO_NEED
  CLIENT_ABSENT
  CALLBACK_REQUIRED
  OTHER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  IN_DELIVERY
  COMPLETED
  CANCELLED
}
